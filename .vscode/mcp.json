{
	"servers": {
		"playwright": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest",
				"--headless"
			],
		},
		"chrome-devtools": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp@latest",
				"--headless"
			],
			"sandboxEnabled": false
		},
		"excalidraw": {
			"type": "http",
			"url": "https://mcp.excalidraw.com/mcp"
		},
		"figma": {
			"type": "http",
			"url": "https://mcp.figma.com/mcp"
		},
		"logfire": {
			"type": "http",
			"url": "https://logfire-us.pydantic.dev/mcp"
		}
	},
	"inputs": []
}