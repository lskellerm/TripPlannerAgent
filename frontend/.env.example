# =============================================================================
# Frontend Environment Variables (.env.example)
# =============================================================================
# Copy this file to `.env` and fill in the values for local development.
# Nuxt automatically reads `.env` at dev/build time.
#
# Variables prefixed with NUXT_PUBLIC_ are exposed to both server and client
# bundles via `useRuntimeConfig().public.*`. Variables without the prefix are
# server-only (available in Nitro server routes / middleware via
# `useRuntimeConfig().*`).
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------

# Base URL of the FastAPI backend. Used by composables and the generated API
# client to make HTTP requests. In Docker Compose this is overridden to the
# internal service name (e.g. http://backend:8000).
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# WebSocket
# -----------------------------------------------------------------------------

# WebSocket endpoint for real-time agent monitoring and streaming responses.
# Defaults to ws:// in dev; use wss:// in production behind TLS.
NUXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# -----------------------------------------------------------------------------
# Server-only (Nitro proxy)
# -----------------------------------------------------------------------------

# API key injected server-side by the Nitro proxy — never sent to the browser.
# Must match the backend's API_KEY value.
NUXT_API_KEY=
