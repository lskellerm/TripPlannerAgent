# ── Application ──
APP_NAME=TripPlannerAgent
ENVIRONMENT=development  # development | production | testing

# ── Ollama (LLM Provider) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=qwen3.5:35b-a3b
OLLAMA_MAX_TOKENS=16384
OLLAMA_TEMPERATURE=0.2
OLLAMA_TIMEOUT=300.0

# ── Authentication ──
# Static API key for frontend → backend auth (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
API_KEY=changeme-generate-a-real-key
# Secret key for agent-scoped JWT signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
AGENT_SECRET_KEY=changeme-generate-a-real-secret

# ── Agent JWT ──
AGENT_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000"]

# ── API ──
API_V1_PREFIX=/api/v1

# ── Airbnb Scraping ──
AIRBNB_SCRAPING_MODE=live  # live | cached

# ── Playwright MCP ──
PLAYWRIGHT_MCP_VERSION=0.0.70
PLAYWRIGHT_OUTPUT_DIR=./.playwright-mcp/html_output

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=10

# ── Observability (optional) ──
LOGFIRE_TOKEN=

# ── FastAPI ──
FASTAPI_TITLE=TripPlannerAgent API
FASTAPI_VERSION=0.1.0
FASTAPI_DESCRIPTION=AI-powered Airbnb search and trip cost analysis API
